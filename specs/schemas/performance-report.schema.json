{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "performance-report.schema.json",
  "title": "CognitiveOS Performance Report",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark_manifest",
    "slo_profile",
    "metrics",
    "safety_failures",
    "tail_latency_disclosed"
  ],
  "properties": {
    "schema_version": {
      "const": "cognitiveos.performance-report/0.1"
    },
    "benchmark_manifest": {
      "type": "object",
      "required": [
        "workload",
        "execution_state",
        "model",
        "hardware_topology",
        "concurrency",
        "datasets",
        "fault_profile",
        "risk_class",
        "samples",
        "confidence_interval",
        "baselines",
        "ablations",
        "latency_boundaries"
      ],
      "properties": {
        "workload": {
          "type": "object"
        },
        "model": {
          "type": "object",
          "required": [
            "provider",
            "model",
            "revision",
            "sampling"
          ]
        },
        "hardware_topology": {
          "type": "object"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "version"
            ]
          }
        },
        "fault_profile": {
          "type": "object"
        },
        "risk_class": {
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3"
          ]
        },
        "samples": {
          "type": "integer",
          "minimum": 1
        },
        "confidence_interval": {
          "type": "object",
          "required": [
            "level",
            "method"
          ]
        },
        "baselines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ablations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "latency_boundaries": {
          "type": "object",
          "required": [
            "mechanism",
            "model_tool_network"
          ]
        },
        "execution_state": {
          "enum": [
            "warm",
            "cold",
            "mixed"
          ]
        }
      },
      "additionalProperties": false
    },
    "slo_profile": {
      "type": "object",
      "required": [
        "id",
        "version",
        "window"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "window": {
          "type": "string"
        },
        "thresholds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "metric",
              "comparator",
              "value",
              "release_gate"
            ],
            "properties": {
              "metric": {
                "type": "string"
              },
              "comparator": {
                "enum": [
                  "lte",
                  "gte",
                  "lt",
                  "gt"
                ]
              },
              "value": {
                "type": "number"
              },
              "percentile": {
                "enum": [
                  "p50",
                  "p95",
                  "p99"
                ]
              },
              "risk_class": {
                "enum": [
                  "R0",
                  "R1",
                  "R2",
                  "R3"
                ]
              },
              "workload_family": {
                "type": "string"
              },
              "release_gate": {
                "type": "boolean"
              },
              "on_breach": {
                "enum": [
                  "block_release",
                  "downgrade_to_experimental",
                  "alert_only"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "category",
          "unit",
          "numerator",
          "denominator",
          "window",
          "p50",
          "p95",
          "p99",
          "sample_count",
          "confidence_interval"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "category": {
            "enum": [
              "context",
              "memory_discovery",
              "catalog_semantic",
              "execution_loop",
              "effects",
              "recovery_distributed",
              "embodied_heterogeneous",
              "security_knowledge",
              "governance_overhead",
              "agent_benefit",
              "cost_energy"
            ]
          },
          "unit": {
            "type": "string"
          },
          "numerator": {
            "type": [
              "number",
              "integer"
            ]
          },
          "denominator": {
            "type": [
              "number",
              "integer"
            ],
            "exclusiveMinimum": 0
          },
          "window": {
            "type": "object",
            "required": [
              "start",
              "end"
            ]
          },
          "p50": {
            "type": "number"
          },
          "p95": {
            "type": "number"
          },
          "p99": {
            "type": "number"
          },
          "sample_count": {
            "type": "integer",
            "minimum": 1
          },
          "confidence_interval": {
            "type": "object",
            "required": [
              "level",
              "low",
              "high",
              "method"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "safety_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "class",
          "count"
        ]
      }
    },
    "governance_overhead": {
      "type": "object",
      "required": [
        "ungoverned_baseline",
        "overhead_share_by_risk_class"
      ],
      "properties": {
        "ungoverned_baseline": {
          "type": "string"
        },
        "gate_latency_ms": {
          "type": "object",
          "properties": {
            "authorization": {
              "$ref": "#/$defs/latency_percentiles"
            },
            "context_resolution": {
              "$ref": "#/$defs/latency_percentiles"
            },
            "effect_protocol": {
              "$ref": "#/$defs/latency_percentiles"
            }
          },
          "additionalProperties": false
        },
        "cache_hit_preservation_ratio": {
          "type": "number",
          "minimum": 0
        },
        "extra_persistence_per_governed_call": {
          "type": "object",
          "properties": {
            "writes": {
              "type": "number",
              "minimum": 0
            },
            "bytes": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "approval": {
          "type": "object",
          "properties": {
            "latency_ms": {
              "$ref": "#/$defs/latency_percentiles"
            },
            "throughput_per_hour": {
              "type": "number",
              "minimum": 0
            },
            "rubber_stamp_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "retry_after_deny_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        },
        "overhead_share_by_risk_class": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "risk_class",
              "latency_percent",
              "cost_percent"
            ],
            "properties": {
              "risk_class": {
                "enum": [
                  "R0",
                  "R1",
                  "R2",
                  "R3"
                ]
              },
              "latency_percent": {
                "type": "number",
                "minimum": 0
              },
              "cost_percent": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "tail_latency_disclosed": {
      "const": true
    },
    "comparison": {
      "type": "object",
      "required": [
        "arms",
        "primary_endpoint",
        "paired",
        "claim_level",
        "preregistration_ref"
      ],
      "properties": {
        "arms": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "arm_id",
              "arm_kind",
              "description"
            ],
            "properties": {
              "arm_id": {
                "type": "string"
              },
              "arm_kind": {
                "enum": [
                  "native_baseline",
                  "governance_only",
                  "optimized",
                  "ablation"
                ]
              },
              "description": {
                "type": "string"
              },
              "manifest_delta": {
                "type": "string"
              },
              "report_ref": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "primary_endpoint": {
          "type": "string"
        },
        "paired": {
          "type": "boolean"
        },
        "workload_family": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "endpoint",
              "arm_a",
              "arm_b",
              "relative_change_percent",
              "confidence_interval",
              "effect_size"
            ],
            "properties": {
              "endpoint": {
                "type": "string"
              },
              "arm_a": {
                "type": "string"
              },
              "arm_b": {
                "type": "string"
              },
              "relative_change_percent": {
                "type": "number"
              },
              "absolute_change": {
                "type": "number"
              },
              "confidence_interval": {
                "type": "object",
                "required": [
                  "level",
                  "low",
                  "high",
                  "method"
                ]
              },
              "effect_size": {
                "type": "object",
                "required": [
                  "kind",
                  "value"
                ],
                "properties": {
                  "kind": {
                    "type": "string"
                  },
                  "value": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              },
              "sample_count": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "ablation_results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "mechanism",
              "endpoint",
              "contribution_percent",
              "confidence_interval"
            ],
            "properties": {
              "mechanism": {
                "type": "string"
              },
              "endpoint": {
                "type": "string"
              },
              "contribution_percent": {
                "type": "number"
              },
              "confidence_interval": {
                "type": "object",
                "required": [
                  "level",
                  "low",
                  "high",
                  "method"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "claim_level": {
          "enum": [
            "hypothesis",
            "non_inferiority",
            "significant_benefit"
          ]
        },
        "preregistration_ref": {
          "type": "string"
        },
        "excluded_samples_declared": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "composite_score": {
      "type": "object",
      "required": [
        "value",
        "non_masking_statement"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "non_masking_statement": {
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "latency_percentiles": {
      "type": "object",
      "required": [
        "p50",
        "p95",
        "p99"
      ],
      "properties": {
        "p50": {
          "type": "number"
        },
        "p95": {
          "type": "number"
        },
        "p99": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  }
}
