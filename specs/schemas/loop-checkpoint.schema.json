{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopCheckpoint",
  "type": "object",
  "required": [
    "header",
    "task_contract_ref",
    "iteration",
    "phase",
    "observation_refs",
    "context_view_ref",
    "action_or_effect_refs",
    "progress",
    "remaining_budget",
    "next_gate",
    "continuation_conditions"
  ],
  "properties": {
    "header": {
      "allOf": [
        {
          "$ref": "governed-object-header.schema.json"
        },
        {
          "properties": {
            "type": {
              "const": "LoopCheckpoint"
            }
          }
        }
      ]
    },
    "task_contract_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "phase": {
      "enum": [
        "START",
        "OBSERVE",
        "RESOLVE",
        "ORIENT",
        "DECIDE",
        "ACT",
        "VERIFY",
        "CONTINUE",
        "DIAGNOSE",
        "WAIT",
        "QUARANTINE",
        "RECONCILE",
        "ESCALATE",
        "STOP",
        "END"
      ]
    },
    "observation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri-reference",
        "minLength": 1
      },
      "minItems": 0
    },
    "context_view_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "proposal_ref": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "action_or_effect_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri-reference",
        "minLength": 1
      },
      "minItems": 0
    },
    "progress": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Progress evidence",
      "type": "object",
      "required": [
        "status",
        "evidence_refs"
      ],
      "properties": {
        "status": {
          "enum": [
            "none",
            "advanced",
            "uncertain",
            "blocked"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri-reference",
            "minLength": 1
          },
          "minItems": 0
        },
        "delta_ref": {
          "type": "string",
          "format": "uri-reference",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "failure_attribution_ref": {
      "oneOf": [
        {
          "type": "string",
          "format": "uri-reference",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "remaining_budget": {
      "$ref": "common-defs.schema.json#/$defs/budget"
    },
    "next_gate": {
      "type": "string",
      "minLength": 1
    },
    "continuation_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "event_high_watermark": {
      "type": "string",
      "minLength": 1,
      "description": "Last consumed committed-event position; recovery replays committed history from here."
    },
    "fencing_epoch": {
      "type": "integer",
      "minimum": 0,
      "description": "Epoch under which this checkpoint was taken; recovery must install a newer epoch before resuming."
    },
    "pending_effects": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "effect_ref",
          "state",
          "idempotency_key"
        ],
        "properties": {
          "effect_ref": {
            "type": "string",
            "format": "uri-reference",
            "minLength": 1
          },
          "state": {
            "enum": [
              "PROPOSED",
              "AUTHORIZED",
              "EXECUTING",
              "EXECUTED",
              "OUTCOME_UNKNOWN",
              "RECONCILED",
              "VERIFIED",
              "VERIFY_FAILED",
              "COMPENSATING"
            ]
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 8
          }
        },
        "additionalProperties": false
      },
      "description": "Typed pending-Effect inventory; recovery must reconcile these before the loop resumes."
    },
    "pinned_environment_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "description": "Digest or version pins for policy, schema bundle, renderer, model, verifier and environment at checkpoint time; recovery revalidates continuation against current versions."
    }
  },
  "additionalProperties": false
}
