{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryAdmissionDecision",
  "type": "object",
  "required": [
    "header",
    "candidate_ref",
    "decision",
    "target_scope",
    "reason_codes",
    "policy_version"
  ],
  "properties": {
    "header": {
      "$ref": "governed-object-header.schema.json"
    },
    "candidate_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "decision": {
      "enum": [
        "admit",
        "reject",
        "review",
        "quarantine"
      ]
    },
    "target_scope": {
      "$ref": "common-defs.schema.json#/$defs/governanceScope"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "policy_version": {
      "type": "integer",
      "minimum": 1
    },
    "result_ref": {
      "$ref": "common-defs.schema.json#/$defs/uriRef"
    }
  },
  "additionalProperties": false
}
