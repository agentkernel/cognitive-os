{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryCandidate",
  "type": "object",
  "required": [
    "header",
    "memory_kind",
    "governance_scope",
    "purpose",
    "retention",
    "source_evidence_refs",
    "conflict_refs",
    "admission_status",
    "content_ref",
    "target_scope"
  ],
  "properties": {
    "header": {
      "$ref": "governed-object-header.schema.json"
    },
    "memory_kind": {
      "enum": [
        "working",
        "episode",
        "conversation",
        "task",
        "subject",
        "procedural",
        "semantic",
        "world_observation",
        "system"
      ]
    },
    "governance_scope": {
      "$ref": "common-defs.schema.json#/$defs/governanceScope"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "retention": {
      "$ref": "common-defs.schema.json#/$defs/retention"
    },
    "source_evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "common-defs.schema.json#/$defs/uriRef"
      }
    },
    "conflict_refs": {
      "type": "array",
      "items": {
        "$ref": "common-defs.schema.json#/$defs/uriRef"
      }
    },
    "admission_status": {
      "enum": [
        "proposed",
        "quarantined",
        "admitted",
        "invalidated",
        "expired",
        "tombstoned"
      ]
    },
    "content_ref": {
      "$ref": "common-defs.schema.json#/$defs/uriRef"
    },
    "target_scope": {
      "$ref": "common-defs.schema.json#/$defs/governanceScope"
    },
    "promotion_from": {
      "$ref": "common-defs.schema.json#/$defs/uriRef"
    },
    "pending_visibility": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Read-your-write working-set binding before admission (REQ-MEM-ADMIT-002)",
      "type": "object",
      "required": [
        "visibility",
        "writer_principal_ref"
      ],
      "properties": {
        "visibility": {
          "enum": [
            "writer_private"
          ]
        },
        "writer_principal_ref": {
          "$ref": "common-defs.schema.json#/$defs/uriRef"
        },
        "activity_ref": {
          "$ref": "common-defs.schema.json#/$defs/uriRef"
        },
        "conversation_ref": {
          "$ref": "common-defs.schema.json#/$defs/uriRef"
        },
        "trust_role": {
          "enum": [
            "working",
            "untrusted_input"
          ]
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
