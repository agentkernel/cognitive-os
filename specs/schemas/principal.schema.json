{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "principal.schema.json",
  "title": "Principal",
  "description": "CognitiveOS v0.1 Draft normative authenticated and auditable subject.",
  "type": "object",
  "required": ["header", "scope_domain", "kind", "authentication_authority_ref", "attributes", "status"],
  "properties": {
    "header": { "$ref": "governed-object-header.schema.json" },
    "scope_domain": { "enum": ["tenant", "platform"] },
    "tenant_id": { "$ref": "object-reference.schema.json#/$defs/uuidV7" },
    "kind": { "enum": ["human", "workload", "device"] },
    "authentication_authority_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "attributes": { "type": "object", "additionalProperties": true },
    "status": { "enum": ["active", "suspended", "revoked"] }
  },
  "allOf": [
    { "if": { "properties": { "scope_domain": { "const": "tenant" } }, "required": ["scope_domain"] }, "then": { "required": ["tenant_id"] } },
    { "if": { "properties": { "scope_domain": { "const": "platform" } }, "required": ["scope_domain"] }, "then": { "not": { "required": ["tenant_id"] } } }
  ],
  "additionalProperties": false
}
