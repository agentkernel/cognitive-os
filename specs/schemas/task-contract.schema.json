{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-contract.schema.json",
  "title": "TaskContract",
  "type": "object",
  "required": [
    "header",
    "task_ref",
    "contract_epoch",
    "intent_acceptance_ref",
    "intent_interpretation_ref",
    "user_intent_ref",
    "objective",
    "scope",
    "conditions",
    "budget",
    "max_iterations",
    "max_retries",
    "allowed_state_domains",
    "allowed_tools"
  ],
  "properties": {
    "header": {
      "allOf": [
        {
          "$ref": "governed-object-header.schema.json"
        },
        {
          "properties": {
            "type": {
              "const": "TaskContract"
            }
          }
        }
      ]
    },
    "task_ref": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Task scope",
      "type": "object",
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 0
        }
      },
      "additionalProperties": false
    },
    "conditions": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Contract condition",
        "type": "object",
        "required": [
          "id",
          "kind",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "acceptance",
              "stop",
              "escalation",
              "wait",
              "constraint"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "verifier_ref": {
            "type": "string",
            "format": "uri-reference",
            "minLength": 1
          },
          "machine_expression": {
            "type": "object"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "budget": {
      "$ref": "common-defs.schema.json#/$defs/budget"
    },
    "max_iterations": {
      "type": "integer",
      "minimum": 1
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0
    },
    "allowed_state_domains": {
      "type": "array",
      "description": "Authority-managed state domain names; the domain registry (specs/registry/state-domains.yaml) is open (domain_name_closed_enum: false), so values are registry domain identifiers, not a closed enum.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri-reference",
        "minLength": 1
      },
      "minItems": 0
    },
    "human_gates": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Human gate",
        "type": "object",
        "required": [
          "id",
          "trigger"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "trigger": {
            "type": "string",
            "minLength": 1
          },
          "approver": {
            "type": "string",
            "format": "uri-reference",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 0
    },
    "user_intent_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "intent_interpretation_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "intent_acceptance_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "contract_epoch": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "description": "A TaskContract must declare at least one acceptance condition so completion is decidable.",
      "properties": {
        "conditions": {
          "contains": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "acceptance"
              }
            },
            "required": [
              "kind"
            ]
          }
        }
      }
    }
  ]
}
