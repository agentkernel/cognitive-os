{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cognitiveos.dev/governance/activity-context/0.1",
  "title": "ActivityContext",
  "description": "CognitiveOS v0.1 Draft activity-level governance package that can only narrow its execution context.",
  "type": "object",
  "required": ["header", "scope_domain", "activity_id", "execution_context_ref", "execution_id", "task_ref", "episode_ref", "actor_chain_digest", "purpose", "resource_scope_ref", "context_view_ref", "capability_refs", "budget_ref", "started_at"],
  "properties": {
    "header": { "$ref": "governed-object-header.schema.json" },
    "scope_domain": { "enum": ["tenant", "platform"] },
    "tenant_id": { "$ref": "object-reference.schema.json#/$defs/uuidV7" },
    "activity_id": { "$ref": "object-reference.schema.json#/$defs/uuidV7" },
    "execution_context_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "execution_id": { "$ref": "object-reference.schema.json#/$defs/uuidV7" },
    "conversation_binding": { "$ref": "conversation-binding.schema.json" },
    "non_conversational_scope_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "task_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "episode_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "actor_chain_digest": { "$ref": "common-defs.schema.json#/$defs/digest" },
    "purpose": { "type": "string", "minLength": 1 },
    "resource_scope_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "context_view_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "capability_refs": { "type": "array", "items": { "$ref": "object-reference.schema.json#/$defs/strongReference" }, "uniqueItems": true },
    "budget_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "started_at": { "type": "string", "format": "date-time" }
  },
  "oneOf": [
    { "required": ["conversation_binding"], "not": { "required": ["non_conversational_scope_ref"] } },
    { "required": ["non_conversational_scope_ref"], "not": { "required": ["conversation_binding"] } }
  ],
  "allOf": [
    { "if": { "properties": { "scope_domain": { "const": "tenant" } }, "required": ["scope_domain"] }, "then": { "required": ["tenant_id"] } },
    { "if": { "properties": { "scope_domain": { "const": "platform" } }, "required": ["scope_domain"] }, "then": { "not": { "required": ["tenant_id"] } } }
  ],
  "additionalProperties": false
}
