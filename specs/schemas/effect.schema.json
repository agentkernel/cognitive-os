{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "effect.schema.json",
  "title": "Effect",
  "type": "object",
  "required": [
    "header",
    "intent_ref",
    "state",
    "executor",
    "attempt",
    "idempotency_key",
    "parameters_digest",
    "authorization_digest",
    "observed_outcome",
    "verification",
    "decision",
    "event_refs"
  ],
  "properties": {
    "header": {
      "allOf": [
        {
          "$ref": "governed-object-header.schema.json"
        },
        {
          "properties": {
            "type": {
              "const": "Effect"
            }
          }
        }
      ]
    },
    "intent_ref": {
      "$ref": "object-reference.schema.json#/$defs/strongReference"
    },
    "state": {
      "enum": [
        "PROPOSED",
        "AUTHORIZED",
        "DENIED",
        "EXECUTING",
        "EXECUTED",
        "OUTCOME_UNKNOWN",
        "NOT_EXECUTED",
        "RECONCILED",
        "VERIFIED",
        "VERIFY_FAILED",
        "COMPENSATING",
        "COMMITTED",
        "ABORTED",
        "QUARANTINED"
      ]
    },
    "executor": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "parameters_digest": {
      "$ref": "common-defs.schema.json#/$defs/digest"
    },
    "authorization_digest": {
      "$ref": "common-defs.schema.json#/$defs/digest"
    },
    "fencing_token": {
      "type": "integer",
      "minimum": 0
    },
    "receipt_ref": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "observed_outcome": {
      "enum": [
        "not_observed",
        "succeeded",
        "failed",
        "unknown"
      ]
    },
    "reconciliation_result": {
      "description": "Persisted reconciliation outcome (Core section 9.5); mirrors the effect.transitions.json guards reconciliation_result_equals_*. Absent before reconciliation completes.",
      "enum": [
        "executed",
        "not_executed",
        "still_unknown"
      ]
    },
    "reconciliation_report_ref": {
      "type": "string",
      "format": "uri-reference",
      "minLength": 1
    },
    "verification": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Effect verification standing",
      "description": "Projection of the current Verification standing for this Effect. The VerificationReport is immutable (status passed|failed|indeterminate); expiry is a Verification lifecycle fact (verification.transitions.json PASSED->EXPIRED) projected here as `expired`, and the commit guard verification_still_current rejects non-current reports.",
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "passed",
            "failed",
            "unresolved",
            "expired"
          ]
        },
        "report_ref": {
          "type": "string",
          "format": "uri-reference",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "enum": [
        "pending",
        "commit",
        "abort",
        "compensate",
        "quarantine"
      ]
    },
    "event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri-reference",
        "minLength": 1
      },
      "minItems": 0
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "const": "COMMITTED"
          }
        }
      },
      "then": {
        "properties": {
          "observed_outcome": {
            "enum": [
              "succeeded",
              "unknown",
              "not_observed"
            ]
          },
          "reconciliation_result": {
            "const": "executed"
          },
          "verification": {
            "properties": {
              "status": {
                "const": "passed"
              }
            },
            "required": [
              "status",
              "report_ref"
            ]
          },
          "decision": {
            "const": "commit"
          }
        },
        "required": [
          "reconciliation_result"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "RECONCILED"
          }
        }
      },
      "then": {
        "required": [
          "reconciliation_result",
          "reconciliation_report_ref"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "VERIFIED"
          }
        }
      },
      "then": {
        "properties": {
          "reconciliation_result": {
            "const": "executed"
          },
          "verification": {
            "properties": {
              "status": {
                "const": "passed"
              }
            },
            "required": [
              "status",
              "report_ref"
            ]
          }
        },
        "required": [
          "reconciliation_result"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "VERIFY_FAILED"
          }
        }
      },
      "then": {
        "properties": {
          "reconciliation_result": {
            "const": "executed"
          },
          "verification": {
            "properties": {
              "status": {
                "enum": [
                  "failed",
                  "unresolved",
                  "expired"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "decision": {
            "enum": [
              "pending",
              "abort",
              "compensate",
              "quarantine"
            ]
          }
        },
        "required": [
          "reconciliation_result"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "OUTCOME_UNKNOWN"
          }
        }
      },
      "then": {
        "properties": {
          "observed_outcome": {
            "enum": [
              "not_observed",
              "unknown"
            ]
          },
          "verification": {
            "properties": {
              "status": {
                "enum": [
                  "pending",
                  "unresolved"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "decision": {
            "enum": [
              "pending",
              "compensate",
              "quarantine"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "enum": [
              "PROPOSED",
              "AUTHORIZED",
              "DENIED",
              "EXECUTING",
              "EXECUTED",
              "OUTCOME_UNKNOWN"
            ]
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "reconciliation_result"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "COMPENSATING"
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "const": "compensate"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "QUARANTINED"
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "const": "quarantine"
          }
        }
      }
    }
  ]
}
