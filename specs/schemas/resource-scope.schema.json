{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cognitiveos.dev/governance/resource-scope/0.1",
  "title": "ResourceScope",
  "description": "CognitiveOS v0.1 Draft governed visibility, derivation, retention, and promotion boundary.",
  "type": "object",
  "required": ["header", "scope_domain", "kind", "audience_constraints", "purpose_constraints", "compartments", "policy_refs"],
  "properties": {
    "header": { "$ref": "governed-object-header.schema.json" },
    "scope_domain": { "enum": ["tenant", "platform"] },
    "tenant_id": { "$ref": "object-reference.schema.json#/$defs/uuidV7" },
    "kind": { "enum": ["private", "conversation", "task", "project", "tenant_shared", "federated_share", "non_conversational", "platform"] },
    "audience_constraints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "purpose_constraints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "compartments": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "parent_scope_ref": { "$ref": "object-reference.schema.json#/$defs/strongReference" },
    "policy_refs": { "type": "array", "items": { "$ref": "object-reference.schema.json#/$defs/strongReference" }, "uniqueItems": true }
  },
  "allOf": [
    { "if": { "properties": { "scope_domain": { "const": "tenant" } }, "required": ["scope_domain"] }, "then": { "required": ["tenant_id"], "properties": { "kind": { "not": { "const": "platform" } } } } },
    { "if": { "properties": { "scope_domain": { "const": "platform" } }, "required": ["scope_domain"] }, "then": { "not": { "required": ["tenant_id"] }, "properties": { "kind": { "const": "platform" } } } }
  ],
  "additionalProperties": false
}
