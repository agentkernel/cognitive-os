{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "review-only privileged_read_decision candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_kind", "record_id", "request_digest", "outcome", "observed_at"],
  "properties": {
    "record_kind": { "const": "privileged_read_decision" },
    "record_id": { "type": "string", "format": "uuid" },
    "request_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "outcome": { "enum": ["success", "denied", "error"] },
    "safe_reason": {
      "type": "string",
      "enum": [
        "STATE_CONFLICT", "STATE_STALE_OBSERVATION", "STATE_STORE_UNAVAILABLE",
        "CONTEXT_INCOMPLETE", "CONTEXT_BUDGET_EXCEEDED", "CONTEXT_AUTH_DENIED",
        "AUTH_CAPABILITY_ATTENUATION_VIOLATION", "AUTH_CAPABILITY_EXPIRED",
        "EFFECT_OUTCOME_UNKNOWN", "EFFECT_RECOVERY_QUARANTINED", "EFFECT_IDEMPOTENCY_CONFLICT",
        "PROTOCOL_MAPPING_INCOMPLETE", "PROTOCOL_SCHEMA_DIGEST_MISMATCH", "VERSION_UNSUPPORTED",
        "CRITICAL_EXTENSION_UNKNOWN", "SCHEMA_MISMATCH", "DIGEST_MISMATCH",
        "RESOURCE_BUDGET_EXHAUSTED", "PROFILE_CIM_CALIBRATION_MISMATCH",
        "PROFILE_LEARNING_PROMOTION_DENIED", "PROFILE_EMBODIED_OBSERVATION_STALE",
        "KNOWLEDGE_SOURCE_INVALIDATED", "KNOWLEDGE_POISON_QUARANTINED",
        "KNOWLEDGE_MAINTENANCE_BOUNDED", "PERFORMANCE_REPORT_INCOMPLETE",
        "MANAGEMENT_SESSION_EXPIRED", "MANAGEMENT_SESSION_REVOKED", "MANAGEMENT_STEP_UP_REQUIRED",
        "MANAGEMENT_SCOPE_MISMATCH", "MANAGEMENT_SELF_AUTHORIZATION_DENIED",
        "MANAGEMENT_INDEPENDENT_APPROVAL_REQUIRED", "AGENT_PACKAGE_VERIFICATION_FAILED",
        "AGENT_ADAPTER_BYPASS_DETECTED", "AGENT_COMPATIBILITY_DEGRADED",
        "MEMORY_ADMISSION_DENIED", "MEMORY_SCOPE_PROMOTION_REQUIRED", "MEMORY_DERIVATION_INVALIDATED",
        "RESOURCE_NOT_DISCOVERABLE", "CONTEXT_RESOLUTION_STAGNATED", "CATALOG_VERSION_STALE",
        "CATALOG_MATCH_INCONCLUSIVE", "NO_AUTHORIZED_OPERATION_CANDIDATE",
        "SEMANTIC_SERVICE_UNAVAILABLE", "SEMANTIC_MATCH_INCONCLUSIVE", "MODEL_EGRESS_DENIED",
        "SEMANTIC_BUDGET_EXHAUSTED", "SHELL_TARGET_AMBIGUOUS", "SHELL_TARGET_NOT_FOUND",
        "SHELL_PREVIEW_STALE", "INTENT_CLARIFICATION_REQUIRED", "INTENT_VERSION_SUPERSEDED",
        "CANCEL_PENDING", "CANCEL_TOO_LATE", "WATCH_CURSOR_STALE", "SHELL_CHANNEL_BINDING_MISMATCH"
      ]
    },
    "result_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "observed_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    { "if": { "properties": { "outcome": { "const": "success" } } }, "then": { "required": ["result_digest"], "not": { "required": ["safe_reason"] } } },
    { "if": { "properties": { "outcome": { "const": "denied" } } }, "then": { "required": ["safe_reason"], "not": { "required": ["result_digest"] } } },
    { "if": { "properties": { "outcome": { "const": "error" } } }, "then": { "required": ["safe_reason"], "not": { "required": ["result_digest"] } } }
  ]
}
